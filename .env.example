# Copy this file to .env and fill in your real keys. Never commit .env.
# Tip: ./install.sh generates this file for you — you rarely need to edit it by hand.

BINANCE_API_KEY=
BINANCE_API_SECRET=

KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# KuCoin and OKX also require an API passphrase (chosen when you create the key).
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=

OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
